# Runtime Environment Variables
#
# These are required for building and running the Slock Flutter app.
# Copy this file to .env and fill in the values, or export them in your shell.
#
# For CI, these are set via GitHub repository secrets/variables.

# API base URL — the backend server endpoint
# Example: https://api.slock.dev or http://localhost:3000
SLOCK_API_BASE_URL=

# Realtime WebSocket URL — for Socket.IO connection
# Example: wss://realtime.slock.dev or ws://localhost:3001
SLOCK_REALTIME_URL=

# Pgyer API key (optional, only needed for manual APK uploads)
# PGYER_API_KEY=
